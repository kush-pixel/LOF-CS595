# ============================================================================
# AI-Assisted Medical Education LLM Application Configuration
# ============================================================================
# This file documents all available environment variables.
# Copy this to .env and fill in your actual values.
# NEVER commit .env — it is in .gitignore
#
# ============================================================================
# LLM PROVIDER SELECTION
# ============================================================================
# Select which LLM backend to use for all text generation tasks.
# Options: "openai" (default) or "ollama"
#
# - "openai": Uses OpenAI's models (GPT-4, etc.) with native structured output.
#   Requires OPENAI_API_KEY. Supports voice-based interviews.
# - "ollama": Uses local Ollama models. Requires Ollama server at OLLAMA_BASE_URL.
#   No API key required. Text-only interview mode.
#
LLM_PROVIDER=ollama

# ============================================================================
# OPENAI CONFIGURATION
# ============================================================================
# Only required if LLM_PROVIDER=openai

# OpenAI API key for authentication
OPENAI_API_KEY=sk-your-openai-key-here

# Model for case generation and evaluation
# Recommended: "gpt-4o" (best for structured outputs)
# Also tested: "gpt-4-turbo", "gpt-4"
OPENAI_MODEL=gpt-4o

# Model for audio transcription and voice synthesis (interview feature)
# Required for voice-based patient interviews
# Only available with OpenAI; not used if using Ollama
OPENAI_AUDIO_MODEL=gpt-4o-audio-preview

# ============================================================================
# OLLAMA CONFIGURATION
# ============================================================================
# Only required if LLM_PROVIDER=ollama
# Ensure Ollama server is running: ollama serve

# Base URL for the Ollama API endpoint
# Default assumes Ollama is running locally on port 11434
OLLAMA_BASE_URL=http://localhost:11434/v1

# Which Ollama model to use
# Popular choices for medical content:
#   - llama3.2:latest        (7B, balanced, good for structured output)
#   - llama2:latest          (7B, larger, better at medical reasoning)
#   - llama3:70b             (70B, most capable, requires more VRAM)
#   - mistral:latest         (7B, fast, decent quality)
#   - neural-chat:latest     (7B, chat optimized)
#   - medllama:latest        (7B, fine-tuned for medical, if available)
#
# Notes on Ollama structured output:
#   - Ollama's JSON mode is less strict than OpenAI's response.parse API
#   - The application includes automatic validation and retry logic
#   - Smaller models may require 2-3 attempts to produce valid JSON
#   - Increase retries if encountering persistent validation failures
#
OLLAMA_MODEL=llama3.2

# ============================================================================
# OTHER LLM PROVIDERS
# ============================================================================
# Optional: Anthropic Claude (fallback evaluation engine)
# If set, Claude will be used as a fallback for evaluation if available
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL connection string for storing cases and transcripts
DATABASE_URL=postgresql://user:password@localhost/medcases

# ============================================================================
# CACHE CONFIGURATION
# ============================================================================
# Redis connection string for caching evaluation results
# Evaluation results are cached for 1 hour to avoid redundant LLM calls
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# FRONTEND
# ============================================================================
# Base URL for the backend API (used by Streamlit frontend)
API_BASE_URL=http://localhost:8000

# ============================================================================
# DEPLOYMENT & USAGE GUIDE
# ============================================================================
#
# USING OPENAI:
#   1. Set LLM_PROVIDER=openai
#   2. Provide a valid OPENAI_API_KEY
#   3. Select appropriate models (OPENAI_MODEL, OPENAI_AUDIO_MODEL)
#   4. No local model management needed
#   5. All features (case generation, evaluation, voice interviews) supported
#   6. Voice-based interviews: Student questions via audio, patient responses via audio
#
# USING OLLAMA:
#   1. Install Ollama: https://ollama.ai
#   2. Start the server: ollama serve
#   3. Pull your desired model: ollama pull llama3.2:latest
#   4. Set LLM_PROVIDER=ollama
#   5. Set OLLAMA_MODEL to match your pulled model
#   6. Adjust OLLAMA_BASE_URL if not running locally on port 11434
#   7. Voice-based interviews will be disabled (text-only interview mode)
#   8. Structured output uses automatic retry logic (3 attempts for eval, 1 for case gen)
#
# PERFORMANCE NOTES WITH OLLAMA:
#   - First inference will download the model if not cached
#   - Evaluation may take 5-30 seconds depending on model size
#   - Retry logic adds 1-2 seconds per failed attempt
#   - Recommended: llama3.2 for balance of quality and speed
#   - For faster generation: use llama2 or mistral
#   - For better quality: use llama3 (full 7B) or larger
#
# STRUCTURED OUTPUT BEHAVIOR:
#   - OpenAI: Uses native responses.parse API for guaranteed schema compliance
#   - Ollama: Uses JSON mode with Pydantic validation + retry logic
#     * Case generation: 1 attempt (fails fast if invalid)
#     * Evaluation: 3 attempts with exponential backoff (more tolerant)
#   - If Ollama consistently fails, try a larger model (llama3 > llama2 > llama3.2)
#   - Set temperature lower (0-0.3) for more deterministic JSON output
#
# ============================================================================

